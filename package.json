{
  "name": "fortress-pipeline2",
  "displayName": "Fortress — Banking Test & Validation",
  "description": "Generate JIRA-driven test suites and run compliance validations via Pipeline 2 (Customer VPC)",
  "version": "2.0.0",
  "publisher": "textmind",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/textmind/vscode-fortress"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "testing",
    "automation",
    "jira",
    "banking",
    "compliance",
    "ofac",
    "bsa",
    "aml",
    "test generation"
  ],
  "activationEvents": [
    "onCommand:fortress.configure",
    "onCommand:fortress.generateTests",
    "onCommand:fortress.viewWorkflow",
    "onCommand:fortress.validateWireTransfer",
    "onCommand:fortress.validateOFAC",
    "onCommand:fortress.validateLoan",
    "onCommand:fortress.checkHealth",
    "onView:fortressJiraPanel",
    "onView:fortressWorkflowPanel",
    "onView:fortressValidationPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fortress.configure",
        "title": "Configure Pipeline 2 URL & API Key",
        "category": "Fortress"
      },
      {
        "command": "fortress.generateTests",
        "title": "Generate Tests from JIRA Story",
        "category": "Fortress"
      },
      {
        "command": "fortress.viewWorkflow",
        "title": "View Workflow Status",
        "category": "Fortress"
      },
      {
        "command": "fortress.validateWireTransfer",
        "title": "Validate Wire Transfer",
        "category": "Fortress"
      },
      {
        "command": "fortress.validateOFAC",
        "title": "Screen OFAC Sanctions",
        "category": "Fortress"
      },
      {
        "command": "fortress.validateLoan",
        "title": "Validate Loan Application",
        "category": "Fortress"
      },
      {
        "command": "fortress.checkHealth",
        "title": "Check Pipeline 2 Health",
        "category": "Fortress"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fortress",
          "title": "Fortress",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "fortress": [
        {
          "id": "fortressJiraPanel",
          "name": "Generate Tests",
          "type": "webview"
        },
        {
          "id": "fortressWorkflowPanel",
          "name": "Workflow Status",
          "type": "webview"
        },
        {
          "id": "fortressValidationPanel",
          "name": "Compliance Validation",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Fortress",
      "properties": {
        "fortress.pipeline2Url": {
          "type": "string",
          "description": "Pipeline 2 base URL. Use the DNS name assigned via API Gateway or your VPC DNS.",
          "default": "http://fortress_api:8000"
        },
        "fortress.apiKey": {
          "type": "string",
          "description": "API key sent as X-API-Key header. Required when Pipeline 2 is exposed via API Gateway outside the VPC.",
          "default": ""
        },
        "fortress.pollIntervalMs": {
          "type": "number",
          "description": "Workflow status polling interval in milliseconds",
          "default": 3000,
          "minimum": 1000,
          "maximum": 30000
        },
        "fortress.pollTimeoutMs": {
          "type": "number",
          "description": "Maximum time to wait for workflow completion in milliseconds",
          "default": 300000,
          "minimum": 10000,
          "maximum": 600000
        }
      }
    },
    "menus": {
      "commandPalette": [
        { "command": "fortress.configure" },
        { "command": "fortress.generateTests" },
        { "command": "fortress.viewWorkflow" },
        { "command": "fortress.validateWireTransfer" },
        { "command": "fortress.validateOFAC" },
        { "command": "fortress.validateLoan" },
        { "command": "fortress.checkHealth" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
